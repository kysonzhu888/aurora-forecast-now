# Cloudflare Pages custom response headers.
# Photos can stay cached; code assets must revalidate because filenames are stable.
/assets/photos/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/assets/og-image.jpg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/styles.css
  Cache-Control: no-cache

/script.js
  Cache-Control: no-cache

/assets/alert.css
  Cache-Control: no-cache

/assets/content-density.css
  Cache-Control: no-cache

/assets/pro.css
  Cache-Control: no-cache

/assets/alert-prompt.js
  Cache-Control: no-cache

/assets/pro-access.js
  Cache-Control: no-cache

/assets/pro-license-state.mjs
  Cache-Control: no-cache
